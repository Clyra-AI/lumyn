        "T2",
        "T2.5",
        "T3"
      ]
    },
    {
      "id": "ws2_record_replay",
      "name": "Record, Redact, Normalize, Replay",
      "risk_class": "medium",
      "tasks": [
        "T4",
        "T5",
        "T6"
      ]
    },
    {
      "id": "ws3_live_verify_ci",
      "name": "Live Verify, Cleanup, Boundaries, CI, Share",
      "risk_class": "high",
      "tasks": [
        "T7",
        "T8",
        "T9",
        "T10"
      ]
