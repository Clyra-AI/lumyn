{
  "factory": {
    "repo_path": "${FACTORY_REPO}",
    "profile_path": "profiles/lumyn.yaml"
  },
  "repos": {
    "lumyn": {
      "repo_path": "..",
      "default_branch": "main",
      "artifact_root": ".factory/artifacts",
      "task_packets": ".factory/artifacts/prd-to-plan/lumyn-migration-mvp/task-packets.json",
      "scope_closure_map": ".factory/artifacts/prd-to-plan/lumyn-migration-mvp/scope-closure-map.json",
      "validation_contract": ".factory/artifacts/prd-to-plan/lumyn-migration-mvp/validation-contract.json",
      "validation_commands": [
        "python3 scripts/validate_repo_pack.py --self-test",
        "python3 scripts/validate_repo_pack.py"
      ],
      "state_dir": "../.factoryd",
      "workspace_root": "../.factoryd/workspaces",
      "branch_prefix": "codex",
      "worker_type": "codex_cli",
      "worker_command": "",
      "runtime_control": {
        "owner": "factoryd-operator",
        "autonomy_level": "restricted",
        "mission_paused": false,
        "mission_canceled": false,
        "disabled_adapters": [],
        "max_write_scope_paths": [],
        "release_freeze": {
          "enabled": false,
          "reason": "",
          "exception_ref": ""
        },
        "launch_request": {
          "requested_action": "continue_mission",
          "requested_adapter": "codex_cli",
          "expected_decision": "allow",
          "reason_code": "within_runtime_control_limits"
        },
        "conflict_behavior": "fail_closed"
      },
      "command_timeout_seconds": 300,
      "worker_timeout_seconds": 1800,
      "lease_ttl_seconds": 3600,
      "mode": "until_blocked",
      "auto_ship": false,
      "shipping": {
        "enabled": false,
        "skip_commit": false,
        "commit_message": "factoryd: complete {task_id}",
        "push_required": false,
        "pr_required": false,
        "ci_required": false,
        "codex_review_required": false,
        "merge_required": false,
        "post_merge_required": false,
        "scope_closure_required": false,
        "push_command": "",
        "open_pr_command": "",
        "ci_command": "",
        "codex_review_command": "",
        "merge_command": "",
        "post_merge_command": "",
        "scope_closure_command": ""
      },
      "approval_posture": "Factory worker grants use only approval, credentials, and network; Factory dispatch does not validate or confer private Lumyn product authority, which Lumyn enforces at each live-action boundary, and no grant implies human merge authority",
      "credential_posture": "no ambient customer or provider secrets; repository commands run through a fail-closed host-isolation backend with exact mounts, sanitized environment, closed host credential/socket/descriptor surfaces, and inherited child restrictions; approved sandbox and GitHub credentials are task-scoped and isolated",
      "network_posture": "offline by default; provider-status, package-registry, sandbox, GitHub branch, and GitHub PR destinations require separate task-scoped allowlists",
      "capability_grants": [],
      "budget": {
        "max_worker_tokens": 0,
        "max_worker_cost_usd": 0,
        "max_run_seconds": 0
      },
      "architecture_budget": {
        "enabled": true,
        "policy_ref": "https://github.com/Clyra-AI/factory/blob/main/docs/standards/architecture-fitness-standard.md#default-budget",
        "warn_line_threshold": 1200,
        "fail_line_threshold": 2500,
        "source_extensions": [".go", ".py", ".ts", ".tsx", ".js", ".jsx"],
        "excluded_dirs": [".git", ".factoryd", ".factory/tmp", "workspaces", ".venv", "__pycache__", "build", "dist", "node_modules", "vendor"],
        "exception_refs": [".factory/artifacts/exceptions/architecture-debt-lumyn-migration-rebaseline.json"]
      },
      "acceptance_ledger": ".factory/artifacts/prd-to-plan/lumyn-migration-mvp/acceptance-ledger.json"
    }
  }
}
