{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumyn.local/lumyn.workflow_contract.schema.json",
  "title": "WorkflowContract",
  "description": "Lumyn WorkflowContract schema.",
  "type": "object",
  "required": [
    "object_type",
    "schema_version",
    "id",
    "version",
    "goal",
    "expected_outcome",
    "context",
    "constraints",
    "state_bindings",
    "steps",
    "validators",
    "cleanup",
    "metadata"
  ],
  "properties": {
    "object_type": {
      "const": "lumyn.workflow_contract"
    },
    "schema_version": {
      "const": "1.0"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "expected_outcome": {
      "type": "object",
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "state_bindings": {
      "type": "object",
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "intent"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "intent": {
            "type": "string"
          },
          "validators": {
            "type": "array"
          }
        },
        "additionalProperties": true
      }
    },
    "validators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "cleanup": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
