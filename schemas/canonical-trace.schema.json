{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumyn.local/lumyn.canonical_trace.schema.json",
  "title": "CanonicalTrace",
  "description": "Lumyn CanonicalTrace schema.",
  "type": "object",
  "required": [
    "object_type",
    "schema_version",
    "trace_id",
    "run_id",
    "workflow_id",
    "lumyn_version",
    "started_at",
    "finished_at",
    "redaction_status",
    "events",
    "proof_strength",
    "metadata"
  ],
  "properties": {
    "object_type": {
      "const": "lumyn.canonical_trace"
    },
    "schema_version": {
      "const": "1.0"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "trace_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string"
    },
    "lumyn_version": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "redaction_status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "applied",
        "unsafe_to_persist",
        "unsafe_to_share",
        "unknown"
      ]
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/normalized_evidence_event"
      }
    },
    "proof_strength": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "normalized_evidence_event": {
      "type": "object",
      "required": [
        "finding_kind",
        "proof_strength",
        "action_boundary_status",
        "security_relevance",
        "fix_target",
        "surface_fingerprint",
        "eval_mode",
        "provider_metadata",
        "corpus_eligible"
      ],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/finding_kind"
        },
        "proof_strength": {
          "$ref": "#/$defs/proof_strength"
        },
        "action_boundary_status": {
          "$ref": "#/$defs/action_boundary_status"
        },
        "security_relevance": {
          "$ref": "#/$defs/security_relevance"
        },
        "fix_target": {
          "type": "string",
          "minLength": 1
        },
        "surface_fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "provider_metadata": {
          "$ref": "#/$defs/provider_metadata"
        },
        "eval_mode": {
          "$ref": "#/$defs/eval_mode"
        },
        "corpus_eligible": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "finding_kind": {
      "type": "string",
      "enum": [
        "none",
        "completion_gap",
        "proof_gap",
        "boundary_violation",
        "redaction_share_failure",
        "eval_failure",
        "docs_api_ambiguity",
        "model_specific_failure",
        "stochastic_failure",
        "cost_duration",
        "source_missing_metadata",
        "context_missing",
        "wrong_tool_or_endpoint",
        "auth_confusion",
        "final_state_mismatch",
        "validator_coverage_gap",
        "forbidden_endpoint_call",
        "scope_escalation",
        "unrelated_resource_access",
        "unexpected_write_action",
        "excessive_api_calls",
        "data_exposure_risk",
        "cleanup_failure",
        "flaky_workflow",
        "baseline_drift_contaminated",
        "classification_uncertain",
        "unenforced_boundary_declared",
        "command_error"
      ]
    },
    "proof_strength": {
      "type": "string",
      "enum": [
        "strong",
        "weak",
        "gap",
        "unknown"
      ]
    },
    "action_boundary_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "not_configured",
        "declared_not_enforced",
        "classification_uncertain",
        "unknown"
      ]
    },
    "security_relevance": {
      "type": "string",
      "enum": [
        "none",
        "safety_relevant",
        "security_relevant",
        "safety_and_security_relevant",
        "unknown"
      ]
    },
    "eval_mode": {
      "type": "string",
      "enum": [
        "not_applicable",
        "surface_only",
        "contract_assisted",
        "unknown"
      ]
    },
    "provider_metadata": {
      "type": "object",
      "required": [
        "applicable",
        "provider",
        "model"
      ],
      "properties": {
        "applicable": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "model_snapshot": {
          "type": "string",
          "minLength": 1
        },
        "base_url": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
