{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumyn.local/lumyn.canonical_trace.schema.json",
  "title": "CanonicalTrace",
  "description": "Lumyn CanonicalTrace schema.",
  "type": "object",
  "required": [
    "object_type",
    "schema_version",
    "trace_id",
    "run_id",
    "workflow_id",
    "lumyn_version",
    "started_at",
    "finished_at",
    "redaction_status",
    "events",
    "proof_strength",
    "metadata"
  ],
  "properties": {
    "object_type": {
      "const": "lumyn.canonical_trace"
    },
    "schema_version": {
      "const": "1.0"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "trace_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string"
    },
    "lumyn_version": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "redaction_status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "applied",
        "unsafe_to_persist",
        "unsafe_to_share",
        "unknown"
      ]
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/normalized_evidence_event"
      }
    },
    "proof_strength": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "normalized_evidence_event": {
      "type": "object",
      "required": [
        "finding_kind",
        "proof_strength",
        "action_boundary_status",
        "security_relevance",
        "fix_target",
        "surface_fingerprint",
        "eval_mode",
        "provider_metadata",
        "corpus_eligible"
      ],
      "properties": {
        "fix_target": {
          "type": "string",
          "minLength": 1
        },
        "surface_fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "provider_metadata": {
          "type": "object",
          "required": [
            "applicable",
            "provider",
            "model"
          ],
          "additionalProperties": true
        },
        "corpus_eligible": {
          "const": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
