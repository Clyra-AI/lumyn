{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumyn.local/lumyn.cassette.schema.json",
  "title": "Cassette",
  "description": "Lumyn Cassette schema.",
  "type": "object",
  "required": [
    "object_type",
    "schema_version",
    "cassette_id",
    "workflow_id",
    "recorded_at",
    "lumyn_version",
    "source_refs",
    "redaction_status",
    "evidence_events",
    "state_bindings",
    "validator_inputs",
    "replay_integrity",
    "metadata"
  ],
  "properties": {
    "object_type": {
      "const": "lumyn.cassette"
    },
    "schema_version": {
      "const": "1.0"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "cassette_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "lumyn_version": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "hash"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "redaction_status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "applied",
        "unsafe_to_persist",
        "unsafe_to_share",
        "unknown"
      ]
    },
    "evidence_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/normalized_evidence_event"
      }
    },
    "state_bindings": {
      "type": "object",
      "additionalProperties": true
    },
    "validator_inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "replay_integrity": {
      "type": "object",
      "required": [
        "source_hashes",
        "cassette_hash",
        "stale_policy"
      ],
      "properties": {
        "source_hashes": {
          "type": "object",
          "additionalProperties": true
        },
        "cassette_hash": {
          "type": "string"
        },
        "stale_policy": {
          "type": "string",
          "enum": [
            "warn_normal_fail_strict"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "normalized_evidence_event": {
      "type": "object",
      "required": [
        "finding_kind",
        "proof_strength",
        "action_boundary_status",
        "security_relevance",
        "fix_target",
        "surface_fingerprint",
        "eval_mode",
        "provider_metadata",
        "corpus_eligible"
      ],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/finding_kind"
        },
        "proof_strength": {
          "$ref": "#/$defs/proof_strength"
        },
        "action_boundary_status": {
          "$ref": "#/$defs/action_boundary_status"
        },
        "security_relevance": {
          "$ref": "#/$defs/security_relevance"
        },
        "fix_target": {
          "type": "string",
          "minLength": 1
        },
        "surface_fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "provider_metadata": {
          "$ref": "#/$defs/provider_metadata"
        },
        "eval_mode": {
          "$ref": "#/$defs/eval_mode"
        },
        "corpus_eligible": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "finding_kind": {
      "type": "string",
      "enum": [
        "none",
        "completion_gap",
        "proof_gap",
        "boundary_violation",
        "redaction_share_failure",
        "eval_failure",
        "docs_api_ambiguity",
        "model_specific_failure",
        "stochastic_failure",
        "cost_duration",
        "source_missing_metadata",
        "context_missing",
        "wrong_tool_or_endpoint",
        "auth_confusion",
        "final_state_mismatch",
        "validator_coverage_gap",
        "forbidden_endpoint_call",
        "scope_escalation",
        "unrelated_resource_access",
        "unexpected_write_action",
        "excessive_api_calls",
        "data_exposure_risk",
        "cleanup_failure",
        "flaky_workflow",
        "baseline_drift_contaminated",
        "classification_uncertain",
        "unenforced_boundary_declared",
        "command_error"
      ]
    },
    "proof_strength": {
      "type": "string",
      "enum": [
        "strong",
        "weak",
        "gap",
        "unknown"
      ]
    },
    "action_boundary_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "not_configured",
        "declared_not_enforced",
        "classification_uncertain",
        "unknown"
      ]
    },
    "security_relevance": {
      "type": "string",
      "enum": [
        "none",
        "safety_relevant",
        "security_relevant",
        "safety_and_security_relevant",
        "unknown"
      ]
    },
    "eval_mode": {
      "type": "string",
      "enum": [
        "not_applicable",
        "surface_only",
        "contract_assisted",
        "unknown"
      ]
    },
    "provider_metadata": {
      "type": "object",
      "required": [
        "applicable",
        "provider",
        "model"
      ],
      "properties": {
        "applicable": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "model_snapshot": {
          "type": "string",
          "minLength": 1
        },
        "base_url": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "applicable": {
                "const": false
              }
            },
            "required": [
              "applicable"
            ]
          },
          "then": {
            "properties": {
              "provider": {
                "const": "not_applicable"
              },
              "model": {
                "const": "not_applicable"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "applicable": {
                "const": true
              }
            },
            "required": [
              "applicable"
            ]
          },
          "then": {
            "properties": {
              "provider": {
                "not": {
                  "const": "not_applicable"
                }
              },
              "model": {
                "not": {
                  "const": "not_applicable"
                }
              }
            }
          }
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
