{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumyn.local/lumyn.command_result.schema.json",
  "title": "CommandResult",
  "description": "Lumyn CommandResult schema.",
  "type": "object",
  "required": [
    "object_type",
    "schema_version",
    "command",
    "status",
    "mode",
    "warnings",
    "errors",
    "artifacts",
    "duration_ms",
    "redaction_status",
    "finding_kind",
    "proof_strength",
    "action_boundary_status",
    "security_relevance",
    "fix_target",
    "surface_fingerprint",
    "eval_mode",
    "provider_metadata",
    "corpus_eligible",
    "metadata"
  ],
  "properties": {
    "object_type": {
      "const": "lumyn.command_result"
    },
    "schema_version": {
      "const": "1.0"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked",
        "warning"
      ]
    },
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "exit_code": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          }
        },
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "type"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "redaction_status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "applied",
        "unsafe_to_persist",
        "unsafe_to_share",
        "unknown"
      ]
    },
    "finding_kind": {
      "$ref": "#/$defs/finding_kind"
    },
    "proof_strength": {
      "$ref": "#/$defs/proof_strength"
    },
    "action_boundary_status": {
      "$ref": "#/$defs/action_boundary_status"
    },
    "security_relevance": {
      "$ref": "#/$defs/security_relevance"
    },
    "fix_target": {
      "type": "string",
      "minLength": 1
    },
    "surface_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "eval_mode": {
      "$ref": "#/$defs/eval_mode"
    },
    "provider_metadata": {
      "$ref": "#/$defs/provider_metadata"
    },
    "corpus_eligible": {
      "const": false
    }
  },
  "$defs": {
    "finding_kind": {
      "type": "string",
      "enum": [
        "none",
        "completion_gap",
        "proof_gap",
        "boundary_violation",
        "redaction_share_failure",
        "eval_failure",
        "docs_api_ambiguity",
        "model_specific_failure",
        "stochastic_failure",
        "cost_duration",
        "source_missing_metadata",
        "context_missing",
        "wrong_tool_or_endpoint",
        "auth_confusion",
        "final_state_mismatch",
        "validator_coverage_gap",
        "forbidden_endpoint_call",
        "scope_escalation",
        "unrelated_resource_access",
        "unexpected_write_action",
        "excessive_api_calls",
        "data_exposure_risk",
        "cleanup_failure",
        "flaky_workflow",
        "baseline_drift_contaminated",
        "classification_uncertain",
        "unenforced_boundary_declared",
        "command_error"
      ]
    },
    "proof_strength": {
      "type": "string",
      "enum": [
        "strong",
        "weak",
        "gap",
        "unknown"
      ]
    },
    "action_boundary_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "not_configured",
        "declared_not_enforced",
        "classification_uncertain",
        "unknown"
      ]
    },
    "security_relevance": {
      "type": "string",
      "enum": [
        "none",
        "safety_relevant",
        "security_relevant",
        "safety_and_security_relevant",
        "unknown"
      ]
    },
    "eval_mode": {
      "type": "string",
      "enum": [
        "not_applicable",
        "surface_only",
        "contract_assisted",
        "unknown"
      ]
    },
    "provider_metadata": {
      "type": "object",
      "required": [
        "applicable",
        "provider",
        "model"
      ],
      "properties": {
        "applicable": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "model_snapshot": {
          "type": "string",
          "minLength": 1
        },
        "base_url": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "applicable": {
                "const": false
              }
            },
            "required": [
              "applicable"
            ]
          },
          "then": {
            "properties": {
              "provider": {
                "const": "not_applicable"
              },
              "model": {
                "const": "not_applicable"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "applicable": {
                "const": true
              }
            },
            "required": [
              "applicable"
            ]
          },
          "then": {
            "properties": {
              "provider": {
                "not": {
                  "const": "not_applicable"
                }
              },
              "model": {
                "not": {
                  "const": "not_applicable"
                }
              }
            }
          }
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
