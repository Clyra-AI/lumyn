{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lumyn.local/lumyn.evidence_event.schema.json",
  "title": "EvidenceEvent",
  "description": "Lumyn EvidenceEvent schema.",
  "type": "object",
  "required": [
    "object_type",
    "schema_version",
    "event_id",
    "run_id",
    "timestamp",
    "source",
    "kind",
    "redaction_status",
    "raw_refs",
    "classification",
    "bindings",
    "confidence",
    "finding_kind",
    "proof_strength",
    "action_boundary_status",
    "security_relevance",
    "fix_target",
    "surface_fingerprint",
    "eval_mode",
    "provider_metadata",
    "corpus_eligible",
    "metadata"
  ],
  "properties": {
    "object_type": {
      "const": "lumyn.evidence_event"
    },
    "schema_version": {
      "const": "1.0"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": [
        "http",
        "agent",
        "cli",
        "validator",
        "system"
      ]
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "redaction_status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "applied",
        "unsafe_to_persist",
        "unsafe_to_share",
        "unknown"
      ]
    },
    "raw_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "classification": {
      "type": "object",
      "required": [
        "action_type",
        "confidence"
      ],
      "properties": {
        "action_type": {
          "type": "string",
          "enum": [
            "read",
            "write",
            "delete",
            "auth",
            "retry",
            "approval",
            "unknown",
            "classification_uncertain"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "inferred",
            "unknown"
          ]
        }
      },
      "additionalProperties": true
    },
    "operation": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "operation_id": {
          "type": "string"
        },
        "action_type": {
          "type": "string",
          "enum": [
            "read",
            "write",
            "delete",
            "auth",
            "retry",
            "approval",
            "unknown",
            "classification_uncertain"
          ]
        },
        "classification_confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "inferred",
            "unknown"
          ]
        }
      },
      "additionalProperties": true
    },
    "request": {
      "type": "object",
      "properties": {
        "ref": {
          "type": "string"
        },
        "headers_redacted": {
          "type": "boolean"
        },
        "body_ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "response": {
      "type": "object",
      "properties": {
        "ref": {
          "type": "string"
        },
        "status_code": {
          "type": "integer"
        },
        "body_ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "bindings": {
      "type": "object",
      "additionalProperties": true
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "inferred",
        "unknown"
      ]
    },
    "finding_kind": {
      "$ref": "#/$defs/finding_kind"
    },
    "proof_strength": {
      "$ref": "#/$defs/proof_strength"
    },
    "action_boundary_status": {
      "$ref": "#/$defs/action_boundary_status"
    },
    "security_relevance": {
      "$ref": "#/$defs/security_relevance"
    },
    "fix_target": {
      "type": "string",
      "minLength": 1
    },
    "surface_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "eval_mode": {
      "$ref": "#/$defs/eval_mode"
    },
    "provider_metadata": {
      "$ref": "#/$defs/provider_metadata"
    },
    "corpus_eligible": {
      "const": false
    }
  },
  "$defs": {
    "finding_kind": {
      "type": "string",
      "enum": [
        "none",
        "completion_gap",
        "proof_gap",
        "boundary_violation",
        "redaction_share_failure",
        "eval_failure",
        "docs_api_ambiguity",
        "model_specific_failure",
        "stochastic_failure",
        "cost_duration",
        "source_missing_metadata",
        "context_missing",
        "wrong_tool_or_endpoint",
        "auth_confusion",
        "final_state_mismatch",
        "validator_coverage_gap",
        "forbidden_endpoint_call",
        "scope_escalation",
        "unrelated_resource_access",
        "unexpected_write_action",
        "excessive_api_calls",
        "data_exposure_risk",
        "cleanup_failure",
        "flaky_workflow",
        "baseline_drift_contaminated",
        "classification_uncertain",
        "unenforced_boundary_declared",
        "command_error"
      ]
    },
    "proof_strength": {
      "type": "string",
      "enum": [
        "strong",
        "weak",
        "gap",
        "unknown"
      ]
    },
    "action_boundary_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "not_configured",
        "declared_not_enforced",
        "classification_uncertain",
        "unknown"
      ]
    },
    "security_relevance": {
      "type": "string",
      "enum": [
        "none",
        "safety_relevant",
        "security_relevant",
        "safety_and_security_relevant",
        "unknown"
      ]
    },
    "eval_mode": {
      "type": "string",
      "enum": [
        "not_applicable",
        "surface_only",
        "contract_assisted",
        "unknown"
      ]
    },
    "provider_metadata": {
      "type": "object",
      "required": [
        "applicable",
        "provider",
        "model"
      ],
      "properties": {
        "applicable": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "model_snapshot": {
          "type": "string",
          "minLength": 1
        },
        "base_url": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "applicable": {
                "const": false
              }
            },
            "required": [
              "applicable"
            ]
          },
          "then": {
            "properties": {
              "provider": {
                "const": "not_applicable"
              },
              "model": {
                "const": "not_applicable"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "applicable": {
                "const": true
              }
            },
            "required": [
              "applicable"
            ]
          },
          "then": {
            "properties": {
              "provider": {
                "not": {
                  "const": "not_applicable"
                }
              },
              "model": {
                "not": {
                  "const": "not_applicable"
                }
              }
            }
          }
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
